# Copy to .env and fill with your keys.
#
# The grey-zone LLM uses OpenRouter’s OpenAI-compatible API
# (https://openrouter.ai/docs). Use a key from https://openrouter.ai/keys

OPENROUTER_API_KEY=your_openrouter_key_her# Some setups use a generic name; either works if you point at OpenRouter:
# OPENAI_API_KEY=your_openrouter_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-5-nano
#
# Optional attribution (recommended by OpenRouter for rankings)
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=Injection Shield

# Optional app settings
# MODEL_PATH=models/injection_clf.pkl
# SECURITY_OUTPUT_DIR=output
# SECURITY_DB_FILENAME=security.db
